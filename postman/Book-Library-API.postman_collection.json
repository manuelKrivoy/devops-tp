              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{token}}",
                  "type": "string"
                }
              ]
            },
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/books/{{bookId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "books",
                "{{bookId}}"
              ]
            }
          }
        }
      ]
    }
  ]
}
